\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Mapas de calor por cortes $z = k$}{13}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Mapas de calor de $\log _{10}[E(x,y,z=k)]$ para seis valores de $z$. Las estrellas cyan indican el mínimo de $E$ en cada corte; las cruces verdes la posición real. A medida que $z$ se acerca a $z^* = -1.212$~km, la mancha oscura (baja energía) se concentra y el mínimo se localiza con mayor precisión.}}{13}{figure.caption.8}\protected@file@percent }
\newlabel{fig:heatmaps}{{2}{13}{Mapas de calor de $\log _{10}[E(x,y,z=k)]$ para seis valores de $z$. Las estrellas cyan indican el mínimo de $E$ en cada corte; las cruces verdes la posición real. A medida que $z$ se acerca a $z^* = -1.212$~km, la mancha oscura (baja energía) se concentra y el mínimo se localiza con mayor precisión}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Corte detallado en el plano óptimo $z^* = -1.212$~km, con líneas de contorno en blanco para evidenciar la forma elipsoidal del mínimo, estaciones sísmicas (triángulos azules), mínimo estimado (estrella cyan) y fuente real (cruz verde).}}{14}{figure.caption.9}\protected@file@percent }
\newlabel{fig:heatmap_opt}{{3}{14}{Corte detallado en el plano óptimo $z^* = -1.212$~km, con líneas de contorno en blanco para evidenciar la forma elipsoidal del mínimo, estaciones sísmicas (triángulos azules), mínimo estimado (estrella cyan) y fuente real (cruz verde)}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Curva $E_{\mathop {\mathgroup \symoperators m\acute  {\dotlessi  }n}}(z)$ y profundidad estimada}{14}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Función reducida $E_{\mathop {\mathgroup \symoperators m\acute  {\dotlessi  }n}}(z)$. La línea roja punteada indica $z^* = -1.212$~km (estimado). La línea verde indica $z_0 = -1.2$~km (real). La zona sombreada muestra el FWHM del pozo mínimo ($\Delta z = 2.48$~km).}}{14}{figure.caption.10}\protected@file@percent }
\newlabel{fig:emin}{{4}{14}{Función reducida $E_{\min }(z)$. La línea roja punteada indica $z^* = -1.212$~km (estimado). La línea verde indica $z_0 = -1.2$~km (real). La zona sombreada muestra el FWHM del pozo mínimo ($\Delta z = 2.48$~km)}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces $E_{\mathop {\mathgroup \symoperators m\acute  {\dotlessi  }n}}(z)$ en escala logarítmica. Permite apreciar el pozo mínimo y la asimetría: el flanco derecho (hacia $z=0$) es más abrupto que el izquierdo (hacia $z=-3$~km).}}{15}{figure.caption.11}\protected@file@percent }
\newlabel{fig:emin_log}{{5}{15}{$E_{\min }(z)$ en escala logarítmica. Permite apreciar el pozo mínimo y la asimetría: el flanco derecho (hacia $z=0$) es más abrupto que el izquierdo (hacia $z=-3$~km)}{figure.caption.11}{}}
