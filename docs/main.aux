\newlabel{fig:trayectoria}{{6}{15}{Evolución de $(x^*(z), y^*(z))$ al variar $z$. Las líneas rojas punteadas marcan los valores reales $x_0=-1.0$~km y $y_0=0.5$~km. La línea gris vertical indica $z^*=-1.212$~km}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Convergencia del método iterativo}{16}{subsection.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Izquierda: evolución de $E(\mathbf  {m}_k)$ en escala logarítmica para los cuatro puntos de partida. Derecha: norma $\|\Delta \mathbf  {m}\|$ por iteración. Todos los inicios convergen al mismo nivel de error, demostrando robustez del método.}}{16}{figure.caption.13}\protected@file@percent }
\newlabel{fig:convergencia}{{7}{16}{Izquierda: evolución de $E(\mathbf {m}_k)$ en escala logarítmica para los cuatro puntos de partida. Derecha: norma $\|\Delta \mathbf {m}\|$ por iteración. Todos los inicios convergen al mismo nivel de error, demostrando robustez del método}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Trayectorias iterativas en el plano $XY$. Los cuadrados son puntos iniciales; los rombos, puntos finales. La estrella dorada es la fuente real. Todos los inicios convergen a la misma solución final.}}{16}{figure.caption.14}\protected@file@percent }
\newlabel{fig:tray_iter}{{8}{16}{Trayectorias iterativas en el plano $XY$. Los cuadrados son puntos iniciales; los rombos, puntos finales. La estrella dorada es la fuente real. Todos los inicios convergen a la misma solución final}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Evolución de cada parámetro $(x_0, y_0, z_0, A_0)$ a lo largo de las iteraciones (inicio cercano). Las líneas rojas punteadas indican los valores reales. La convergencia de $x_0$ e $y_0$ es muy rápida; la de $z_0$ y $A_0$ requiere más iteraciones.}}{17}{figure.caption.15}\protected@file@percent }
\newlabel{fig:param_evol}{{9}{17}{Evolución de cada parámetro $(x_0, y_0, z_0, A_0)$ a lo largo de las iteraciones (inicio cercano). Las líneas rojas punteadas indican los valores reales. La convergencia de $x_0$ e $y_0$ es muy rápida; la de $z_0$ y $A_0$ requiere más iteraciones}{figure.caption.15}{}}
